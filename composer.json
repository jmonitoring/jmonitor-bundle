{
    "name": "jmonitoring/jmonitor-bundle",
    "description": "Integration of jmonitor monitoring library in symfony.",
    "keywords": ["monitoring", "metrics", "mysql", "apache", "php", "redis", "nginx", "system", "symfony"],
    "homepage": "https://jmonitor.io",
    "type": "symfony-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Johndodev",
            "homepage": "https://jonathan-plantey.fr/"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.1",
        "jmonitoring/jmonitor": "dev-master",
        "nyholm/psr7": "^1.8",
        "symfony/console": "^6.4|^7.0",
        "symfony/framework-bundle": "^6.4|^7.0",
        "symfony/http-client": "^6.4|^7.0"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "autoload": {
        "psr-4": { "Jmonitor\\JmonitorBundle\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "Jmonitor\\JmonitorBundle\\Tests\\": "tests/" }
    }
}
